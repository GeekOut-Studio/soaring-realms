--!strict
-- Bakes inventory-icon decals for items declared in src/Shared/Defs/ItemDefs.luau,
-- by orchestrating the IconBaker Studio plugin over HTTP.
--
-- Loop per item:
--   1. Plugin polls GET /next-job, lune returns { kind, assetPath } or { done = true }.
--   2. Plugin renders the model in a fullscreen ViewportFrame and calls
--      CaptureService:CaptureScreenshot, which writes a PNG into
--      %LOCALAPPDATA%\Roblox\InternalCaptures\.
--   3. Plugin POSTs /captured with { kind }.
--   4. Lune finds the newest .png in InternalCaptures (mtime > pre-job snapshot),
--      copies it to build/icon-pngs/<Kind>.png, and queues it for decal upload.
--
-- After all items are captured, lune shells out to scripts/upload-asset.sh image
-- for each PNG to produce decal asset ids, then writes the merged manifest to
-- src/Shared/Defs/ItemIcons.luau.

local fs = require("@lune/fs")
local net = require("@lune/net")
local process = require("@lune/process")
local serde = require("@lune/serde")
local stdio = require("@lune/stdio")
local task = require("@lune/task")

local ITEM_DEFS_PATH = "src/Shared/Defs/ItemDefs.luau"
local MANIFEST_PATH = "src/Shared/Defs/ItemIcons.luau"
local PNG_DIR = "build/icon-pngs"
local CAPTURES_DIR = (process.env.LOCALAPPDATA or "") .. "\\Roblox\\tmp-capture-storage"
local SERVER_PORT = 9876
local CAPTURE_TIMEOUT_SECONDS = 30
local POLL_INTERVAL_SECONDS = 0.5

local function die(msg: string): never
	stdio.ewrite("error: " .. msg .. "\n")
	process.exit(1)
	error("unreachable")
end

local function parseItemDefs(source: string): { [string]: string }
	local result: { [string]: string } = {}
	local depth = 0
	local currentKind: string? = nil
	for line in string.gmatch(source, "[^\n]+") do
		local kind = string.match(line, "^%s*(%w+) = {%s*$")
		if kind ~= nil and depth == 1 then
			currentKind = kind
		end
		if currentKind ~= nil then
			local assetPath = string.match(line, '^%s*AssetPath = "([^"]+)"')
			if assetPath ~= nil then
				result[currentKind] = assetPath
			end
		end
		for _ in string.gmatch(line, "{") do
			depth += 1
		end
		for _ in string.gmatch(line, "}") do
			depth -= 1
		end
		if depth <= 1 then
			currentKind = nil
		end
	end
	return result
end

type ManifestEntry = { ImageAssetId: number }

local function parseManifest(source: string): { [string]: ManifestEntry }
	local result: { [string]: ManifestEntry } = {}
	for kind, body in string.gmatch(source, "(%w+)%s*=%s*{([^}]+)}") do
		local imageId = string.match(body, "ImageAssetId%s*=%s*(%d+)")
		if imageId ~= nil then
			result[kind] = { ImageAssetId = assert(tonumber(imageId), "non-numeric ImageAssetId") }
		end
	end
	return result
end

local function serializeManifest(entries: { [string]: ManifestEntry }): string
	local kinds = {}
	for kind in entries do
		table.insert(kinds, kind)
	end
	table.sort(kinds)
	local lines = {
		"--!strict",
		"-- Generated by scripts/lune/bake-icons.luau. Do not edit by hand.",
		"",
		"export type IconEntry = { ImageAssetId: number }",
		"",
		"return {",
	}
	for _, kind in kinds do
		table.insert(lines, string.format("\t%s = { ImageAssetId = %d },", kind, entries[kind].ImageAssetId))
	end
	table.insert(lines, "} :: { [string]: IconEntry }")
	table.insert(lines, "")
	return table.concat(lines, "\n")
end

local function listCapturesByMtime(): { { path: string, mtime: number } }
	if not fs.isDir(CAPTURES_DIR) then
		return {}
	end
	local entries = {}
	for _, name in fs.readDir(CAPTURES_DIR) do
		-- Files are named `wob-NNNNNNN` with no extension; PNG bytes inside.
		local fullPath = CAPTURES_DIR .. "\\" .. name
		local meta = fs.metadata(fullPath)
		if meta.kind == "file" and meta.modifiedAt ~= nil then
			table.insert(entries, { path = fullPath, mtime = meta.modifiedAt.unixTimestampMillis })
		end
	end
	return entries
end

-- Wait for two new captures (white-bg then black-bg) to appear after `sinceMtime`.
-- Returns (whitePath, blackPath) in capture order, or nil on timeout.
local function awaitCapturePair(sinceMtime: number): (string?, string?)
	local elapsed = 0
	while elapsed < CAPTURE_TIMEOUT_SECONDS do
		local newEntries: { { path: string, mtime: number } } = {}
		for _, entry in listCapturesByMtime() do
			if entry.mtime > sinceMtime then
				table.insert(newEntries, entry)
			end
		end
		if #newEntries >= 2 then
			table.sort(newEntries, function(a, b)
				return a.mtime < b.mtime
			end)
			task.wait(0.3)
			local white = newEntries[#newEntries - 1].path
			local black = newEntries[#newEntries].path
			return white, black
		end
		task.wait(POLL_INTERVAL_SECONDS)
		elapsed += POLL_INTERVAL_SECONDS
	end
	return nil, nil
end

local ASSETS_ENDPOINT = "https://apis.roblox.com/assets/v1/assets"
local OPERATION_ENDPOINT_FMT = "https://apis.roblox.com/assets/v1/operations/%s"

-- Direct Open Cloud upload as assetType=Image. rbxcloud's CLI only exposes
-- decal-png (which creates a Decal wrapping an Image and returns the Decal id);
-- posting as "Image" returns the underlying Image id directly, which is what
-- ImageLabel.Image actually needs.
local function uploadImage(pngPath: string, displayName: string, apiKey: string, groupId: string): number
	local bytes = fs.readFile(pngPath)
	local boundary = "----LuneBakeIconsBoundary" .. tostring(math.random(1, 1000000000))
	local metadata = serde.encode("json", {
		assetType = "Image",
		displayName = displayName,
		description = "Inventory icon for " .. displayName .. ". Generated by scripts/lune/bake-icons.luau.",
		creationContext = { creator = { groupId = groupId } },
	})

	local parts = {
		"--" .. boundary,
		'Content-Disposition: form-data; name="request"',
		"Content-Type: application/json",
		"",
		metadata,
		"--" .. boundary,
		string.format('Content-Disposition: form-data; name="fileContent"; filename="%s.png"', displayName),
		"Content-Type: image/png",
		"",
	}
	local body = table.concat(parts, "\r\n") .. "\r\n" .. bytes .. "\r\n--" .. boundary .. "--\r\n"

	local response = net.request({
		url = ASSETS_ENDPOINT,
		method = "POST",
		headers = {
			["x-api-key"] = apiKey,
			["Content-Type"] = "multipart/form-data; boundary=" .. boundary,
		},
		body = body,
	})
	if not response.ok then
		die(string.format("upload failed (%d): %s", response.statusCode, response.body))
	end
	local opId = string.match(response.body, '"operationId"%s*:%s*"([^"]+)"')
	if opId == nil then
		opId = string.match(response.body, "operations/([^\"]+)")
	end
	if opId == nil then
		die("could not parse operation id from: " .. response.body)
	end

	for _ = 1, 30 do
		task.wait(2)
		local poll = net.request({
			url = string.format(OPERATION_ENDPOINT_FMT, opId),
			method = "GET",
			headers = { ["x-api-key"] = apiKey },
		})
		if not poll.ok then
			die(string.format("poll failed (%d): %s", poll.statusCode, poll.body))
		end
		if string.find(poll.body, '"done"%s*:%s*true') ~= nil then
			local assetId = string.match(poll.body, '"assetId"%s*:%s*"?(%d+)"?')
			if assetId == nil then
				die("operation done but no assetId: " .. poll.body)
			end
			return assert(tonumber(assetId), "non-numeric asset id")
		end
	end
	return die("upload operation " .. opId .. " timed out")
end

local function main()
	local apiKey = process.env.ROBLOX_API_KEY
	local groupId = process.env.ROBLOX_GROUP_ID
	if apiKey == nil or apiKey == "" then
		die("ROBLOX_API_KEY not set (dot-source .env.ps1 first)")
	end
	if groupId == nil or groupId == "" then
		die("ROBLOX_GROUP_ID not set (dot-source .env.ps1 first)")
	end

	local defsSource = fs.readFile(ITEM_DEFS_PATH)
	local itemDefs = parseItemDefs(defsSource)

	local manifest: { [string]: ManifestEntry } = {}
	if fs.isFile(MANIFEST_PATH) then
		manifest = parseManifest(fs.readFile(MANIFEST_PATH))
	end

	if not fs.isDir(PNG_DIR) then
		fs.writeDir(PNG_DIR)
	end

	local queue: { { kind: string, assetPath: string } } = {}
	for kind, assetPath in itemDefs do
		local existing = manifest[kind]
		if existing == nil or existing.ImageAssetId == nil then
			table.insert(queue, { kind = kind, assetPath = assetPath })
		end
	end
	table.sort(queue, function(a, b)
		return a.kind < b.kind
	end)

	if #queue == 0 then
		print("Manifest is up to date.")
		return
	end

	print(string.format("%d item(s) to bake:", #queue))
	for _, job in queue do
		print("  - " .. job.kind)
	end
	print("")

	local pendingPngs: { { kind: string, white: string, black: string } } = {}
	local jobIndex = 0
	local currentSinceMtime = 0
	local serverHandle: net.ServeHandle? = nil
	local allDone = false

	local handle = net.serve(SERVER_PORT, function(request)
		if request.method == "GET" and request.path == "/next-job" then
			jobIndex += 1
			if jobIndex > #queue then
				allDone = true
				return {
					status = 200,
					headers = { ["Content-Type"] = "application/json" },
					body = serde.encode("json", { done = true }),
				}
			end
			local job = queue[jobIndex]
			-- Snapshot the latest mtime in the captures folder so the post-capture
			-- diff knows what counts as "new" for this job.
			currentSinceMtime = 0
			for _, entry in listCapturesByMtime() do
				if entry.mtime > currentSinceMtime then
					currentSinceMtime = entry.mtime
				end
			end
			print(string.format("[%d/%d] dispatching %s (%s)", jobIndex, #queue, job.kind, job.assetPath))
			return {
				status = 200,
				headers = { ["Content-Type"] = "application/json" },
				body = serde.encode("json", { kind = job.kind, assetPath = job.assetPath }),
			}
		elseif request.method == "POST" and request.path == "/captured" then
			local payload = serde.decode("json", request.body) :: { kind: string }
			local whitePath, blackPath = awaitCapturePair(currentSinceMtime)
			if whitePath == nil or blackPath == nil then
				stdio.ewrite(string.format("[%s] capture pair did not appear within %ds\n", payload.kind, CAPTURE_TIMEOUT_SECONDS))
				return { status = 500, body = "capture pair did not appear" }
			end
			local whiteDest = PNG_DIR .. "/" .. payload.kind .. "-white.png"
			local blackDest = PNG_DIR .. "/" .. payload.kind .. "-black.png"
			fs.copy(whitePath, whiteDest, true)
			fs.copy(blackPath, blackDest, true)
			table.insert(pendingPngs, { kind = payload.kind, white = whiteDest, black = blackDest })
			print(string.format("    captured -> %s + %s", whiteDest, blackDest))
			return { status = 200, body = "ok" }
		elseif request.method == "POST" and request.path == "/error" then
			local payload = serde.decode("json", request.body) :: { kind: string, message: string }
			stdio.ewrite(string.format("[%s] plugin reported error: %s\n", payload.kind, payload.message))
			return { status = 200, body = "ok" }
		end
		return { status = 404, body = "not found" }
	end)
	serverHandle = handle

	print("HTTP server listening on http://127.0.0.1:" .. tostring(SERVER_PORT))
	print("Click the IconBaker plugin button in Studio to begin.")
	print("")

	while not allDone do
		task.wait(0.2)
	end
	-- Give the final /captured request a chance to settle before shutting down.
	task.wait(1)
	if serverHandle ~= nil then
		serverHandle:stop()
	end

	print("")
	print(string.format("Processing + uploading %d icon(s)...", #pendingPngs))
	for _, item in pendingPngs do
		local out = PNG_DIR .. "/" .. item.kind .. ".png"
		local result = process.exec("python", { "scripts/process-icon.py", item.white, item.black, out })
		if not result.ok then
			die(string.format("process-icon.py failed for %s:\n%s\n%s", item.kind, result.stderr, result.stdout))
		end
		local imageId = uploadImage(out, item.kind, apiKey, groupId)
		print(string.format("  %s -> rbxassetid://%d", item.kind, imageId))
		local existing = manifest[item.kind] or {}
		existing.ImageAssetId = imageId
		manifest[item.kind] = existing
	end

	fs.writeFile(MANIFEST_PATH, serializeManifest(manifest))
	print("Wrote manifest to " .. MANIFEST_PATH)
end

main()
