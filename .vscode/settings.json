{
  "luau-lsp.completion.enabled": true,
  "luau-lsp.completion.imports.enabled": true,
  "luau-lsp.completion.imports.requireStyle": "alwaysAbsolute",
  "luau-lsp.completion.imports.suggestRequires": true,
  "luau-lsp.completion.imports.suggestServices": true,
  "luau-lsp.completion.imports.separateGroupsWithLine": true,
  "luau-lsp.ignoreGlobs": ["**/_Index/**"],
  "stylua.targetReleaseVersion": "latest",
  "search.exclude": {
    "**/*.rbxm": true
  },
  "editor.formatOnSave": true,
  "editor.defaultFormatter": "JohnnyMorganz.stylua",
  "editor.insertSpaces": false,
  "editor.tabSize": 4,
  "[json]": {
    "editor.defaultFormatter": "esbenp.prettier-vscode"
  },
  "[jsonc]": {
    "editor.defaultFormatter": "esbenp.prettier-vscode"
  },
  "[snippets]": {
    "editor.defaultFormatter": "esbenp.prettier-vscode"
  },
}
